    { "id": 3, "module": "google-email:ActionSendEmail", "version": 4, "parameters": { "__IMTCONN__": "{{CONNECTION_GMAIL}}" }, "mapper": { "to": "{{2.guest_email_snapshot}}", "subject": "About your stay at The Namkhan", "html": "<div style=\"font-family:Georgia,serif;max-width:520px;margin:0 auto;padding:32px;background:#f4ecd8\"><p style=\"font-size:16px;line-height:1.65;color:#1c1815\">Dear {{2.guest_name_snapshot}},</p><p style=\"font-size:15px;line-height:1.65;color:#1c1815\">We held the room for two weeks. The dates have moved on but you haven't, and we wanted to write before this drifts.</p><p style=\"font-size:15px;line-height:1.65;color:#1c1815\">If the timing didn't work, tell us and we'll redraw the rates around dates that do. If something else happened, no need to explain — just say and we'll close the file.</p><p style=\"font-size:15px;line-height:1.65;font-style:italic;color:#4a443c\">Sebastian, on behalf of the Namkhan team.</p></div>" }, "metadata": { "comment": "Re-engagement email" } },
    { "id": 4, "module": "supabase:update", "version": 1, "parameters": { "__IMTCONN__": "{{CONNECTION_SUPABASE}}" }, "mapper": { "schema": "sales", "table": "proposals", "id_field": "id", "id_value": "{{2.id}}", "data": { "status": "expired" } }, "metadata": { "comment": "Mark proposal as expired" } }
  ],
  "metadata": { "version": 1, "scenario": { "roundtrips": 1, "maxErrors": 3, "autoCommit": true }, "notes": "Generated 2026-05-03. Set Make scheduler to daily 07:00 ICT. Connection requires Supabase service_role key." }
