# =====================================================================
# .env.example · retreat-compiler
# Copy to .env.staging.local or .env.production.local and fill in values.
# Vercel env should mirror these exactly per environment.
# =====================================================================

# --- Supabase ---------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...                    # public — OK in client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...             # server only — NEVER ship to client
SUPABASE_DB_URL=postgresql://postgres:PWD@db.YOUR_PROJECT.supabase.co:5432/postgres  # migrations only
NEXT_PUBLIC_SUPABASE_URL=$SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY

# --- Cloudbeds --------------------------------------------------------
CLOUDBEDS_CLIENT_ID=
CLOUDBEDS_CLIENT_SECRET=                         # rotate annually
CLOUDBEDS_PROPERTY_ID=                           # confirm with PBS
CLOUDBEDS_REFRESH_TOKEN=                         # OAuth dance
CLOUDBEDS_API_BASE=https://api.cloudbeds.com/api/v1.2

# --- Stripe ----------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_... | sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_test_... | pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$STRIPE_PUBLISHABLE_KEY

# --- Klaviyo ---------------------------------------------------------
KLAVIYO_PRIVATE_KEY=pk_...
KLAVIYO_PUBLIC_KEY=...
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=$KLAVIYO_PUBLIC_KEY

# --- Make.com (webhook plumbing) -------------------------------------
MAKE_WEBHOOK_BASE=https://hook.eu2.make.com/SCENARIO_BASE
MAKE_WEBHOOK_SECRET=                              # generate: openssl rand -hex 32

# --- Anthropic (compiler model) --------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
COMPILER_MODEL=claude-sonnet-4-6
COMPILER_COST_CAP_EUR=0.20

# --- Resend (transactional only) -------------------------------------
RESEND_API_KEY=re_...

# --- Analytics + Pixels ----------------------------------------------
META_PIXEL_ID=
GA4_MEASUREMENT_ID=G-...
GA4_API_SECRET=
NEXT_PUBLIC_META_PIXEL_ID=$META_PIXEL_ID
NEXT_PUBLIC_GA4_MEASUREMENT_ID=$GA4_MEASUREMENT_ID

# --- Cloudflare ------------------------------------------------------
CLOUDFLARE_API_TOKEN=                             # 1Password only — NEVER in Vercel env
CLOUDFLARE_ZONE_ID=

# --- Vercel ----------------------------------------------------------
VERCEL_TOKEN=                                     # 1Password only
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# --- App config ------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://thenamkhan.com
NEXT_PUBLIC_PROPERTY_ID=namkhan
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_BASE_CURRENCY=LAK
NEXT_PUBLIC_TIMEZONE=Asia/Vientiane

# --- Pricing rules ---------------------------------------------------
FX_LOCK_DAYS=7
MARGIN_FLOOR_ACTIVITIES_PCT=35
MARGIN_FLOOR_ROOMS_PCT=60
MARGIN_FLOOR_FNB_PCT=70

# --- Cron + monitoring -----------------------------------------------
CRON_SECRET=                                      # generate: openssl rand -hex 32
LOG_LEVEL=info                                    # debug | info | warn | error
SENTRY_DSN=                                       # optional v1
SENTRY_ENVIRONMENT=staging|production

# --- Feature flags ---------------------------------------------------
ENABLE_SHEETS_SYNC=false
ENABLE_DONNA_FORK=false
ENABLE_MULTI_LANGUAGE=false
